# Oracle VM deployment settings.
# Copy this file to deploy/oracle/.env on the VM and edit the values before deploy.

# Public hostname pointed at the backend VM.
# Current free HTTPS hostname for the GCP VM: 34.29.0.6.sslip.io
TRIPPI_DOMAIN=34.29.0.6.sslip.io

# Must match the public HTTPS URL. Used by MCP OAuth metadata, emails, and links.
APP_URL=https://trippi-ai.vercel.app
ALLOWED_ORIGINS=https://trippi-ai.vercel.app,https://34.29.0.6.sslip.io

# Generate on the VM with:
#   openssl rand -hex 32
ENCRYPTION_KEY=replace-with-64-hex-chars

# First admin only. Ignored after the first user exists.
ADMIN_EMAIL=admin@trippi.local
ADMIN_PASSWORD=replace-with-a-long-random-password

NODE_ENV=production
PORT=3000
TZ=UTC
LOG_LEVEL=info
DEFAULT_LANGUAGE=en

# Caddy terminates TLS and forwards to the app container.
FORCE_HTTPS=true
TRUST_PROXY=1
COOKIE_SECURE=true

# Keep demo reset behavior off for production.
DEMO_MODE=false

# Oracle Autonomous Database mirror mode. Requests are served from local SQLite
# for speed while a background job restores/syncs the data to Oracle.
TRIPPI_DB_PROVIDER=oracle
# ORACLE_DB_USER=ADMIN
# ORACLE_DB_PASSWORD=replace-with-oracle-db-password
# ORACLE_DB_CONNECT_STRING=replace-with-wallet-service-name
# ORACLE_DB_WALLET_LOCATION=/opt/trippi/oracle-wallet
# TNS_ADMIN=/opt/trippi/oracle-wallet
#
# Danger/debug only: the native Oracle compatibility shim blocks Node's event
# loop during DB calls. Do not enable this for production traffic until the DB
# layer is rewritten async end-to-end.
# TRIPPI_DB_PROVIDER=oracle-native
# ORACLE_NATIVE_ALLOW_BLOCKING=true

# MCP defaults. Raise only if your ChatGPT/Claude connector usage needs it.
MCP_RATE_LIMIT=300
MCP_MAX_SESSION_PER_USER=200

# Production media storage. Keep uploaded user media off the VM filesystem.
# The bucket has public access prevention enabled; signed URLs are minted after
# the app authorizes the request, so Node does not stream every media byte.
TRIPPI_MEDIA_BACKEND=gcs
TRIPPI_GCS_BUCKET=trippi-prod-media-project-3ad3d06e-bcb7-4ecf-a7e
TRIPPI_GCS_PREFIX=prod
TRIPPI_MEDIA_DELIVERY=signed-url
TRIPPI_MEDIA_SIGNED_URL_TTL_SECONDS=300

# Persistent host paths on the Oracle VM. The install script creates these.
TRIPPI_DATA_DIR=/opt/trippi/data
TRIPPI_UPLOADS_DIR=/opt/trippi/uploads
TRIPPI_CADDY_DATA_DIR=/opt/trippi/caddy/data
TRIPPI_CADDY_CONFIG_DIR=/opt/trippi/caddy/config
