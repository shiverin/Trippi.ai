{
  "installCommand": "npm ci",
  "buildCommand": "npm run build --workspace=shared && npm run build --workspace=client",
  "outputDirectory": "client/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://discounted-extremely-officer-reprint.trycloudflare.com/api/:path*"
    },
    {
      "source": "/mcp",
      "destination": "https://discounted-extremely-officer-reprint.trycloudflare.com/mcp"
    },
    {
      "source": "/oauth/authorize",
      "destination": "https://discounted-extremely-officer-reprint.trycloudflare.com/oauth/authorize"
    },
    {
      "source": "/oauth/register",
      "destination": "https://discounted-extremely-officer-reprint.trycloudflare.com/oauth/register"
    },
    {
      "source": "/oauth/token",
      "destination": "https://discounted-extremely-officer-reprint.trycloudflare.com/oauth/token"
    },
    {
      "source": "/oauth/revoke",
      "destination": "https://discounted-extremely-officer-reprint.trycloudflare.com/oauth/revoke"
    },
    {
      "source": "/oauth/userinfo",
      "destination": "https://discounted-extremely-officer-reprint.trycloudflare.com/oauth/userinfo"
    },
    {
      "source": "/.well-known/:path*",
      "destination": "https://discounted-extremely-officer-reprint.trycloudflare.com/.well-known/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://discounted-extremely-officer-reprint.trycloudflare.com/uploads/:path*"
    },
    {
      "source": "/ws",
      "destination": "https://discounted-extremely-officer-reprint.trycloudflare.com/ws"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
