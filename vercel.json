{
  "installCommand": "npm ci",
  "buildCommand": "npm run build --workspace=shared && npm run build --workspace=client",
  "outputDirectory": "client/dist",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "trippi.lol"
        }
      ],
      "destination": "https://www.trippi.lol/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/login",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    },
    {
      "source": "/register",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    },
    {
      "source": "/forgot-password",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    },
    {
      "source": "/reset-password",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    },
    {
      "source": "/dashboard",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    },
    {
      "source": "/trips/:path*",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    },
    {
      "source": "/admin",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    },
    {
      "source": "/settings",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    },
    {
      "source": "/mcp-connect",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    },
    {
      "source": "/vacay",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    },
    {
      "source": "/atlas",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    },
    {
      "source": "/friends",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    },
    {
      "source": "/journey",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    },
    {
      "source": "/journey/:path*",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    },
    {
      "source": "/notifications",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    },
    {
      "source": "/shared/:path*",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    },
    {
      "source": "/public/journey/:path*",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    },
    {
      "source": "/oauth/:path*",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://34.29.0.6.sslip.io/api/:path*"
    },
    {
      "source": "/mcp",
      "destination": "https://34.29.0.6.sslip.io/mcp"
    },
    {
      "source": "/oauth/authorize",
      "destination": "https://34.29.0.6.sslip.io/oauth/authorize"
    },
    {
      "source": "/oauth/register",
      "destination": "https://34.29.0.6.sslip.io/oauth/register"
    },
    {
      "source": "/oauth/token",
      "destination": "https://34.29.0.6.sslip.io/oauth/token"
    },
    {
      "source": "/oauth/revoke",
      "destination": "https://34.29.0.6.sslip.io/oauth/revoke"
    },
    {
      "source": "/oauth/userinfo",
      "destination": "https://34.29.0.6.sslip.io/oauth/userinfo"
    },
    {
      "source": "/.well-known/:path*",
      "destination": "https://34.29.0.6.sslip.io/.well-known/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://34.29.0.6.sslip.io/uploads/:path*"
    },
    {
      "source": "/ws",
      "destination": "https://34.29.0.6.sslip.io/ws"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
