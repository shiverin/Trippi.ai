(trippi_backend) {
    encode zstd gzip

    # Backup restores and itinerary imports can be large.
    request_body {
        max_size 500MB
    }

    reverse_proxy app:3000 {
        # Vercel and browsers should reach the named backend over HTTPS.
        # Preserve the original scheme for app redirects/cookies when a TLS
        # proxy is in front of the Node process.
        header_up X-Forwarded-Proto https
    }
}

http://:80 {
    @backend_domain host {$TRIPPI_DOMAIN}
    redir @backend_domain https://{host}{uri} permanent
    import trippi_backend
}

{$TRIPPI_DOMAIN} {
    import trippi_backend
}
